<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('extras/head') %>
</head>
<body class="tl-body">
  <%- include("extras/header", { user: user }) %>
  <main class="tl-shell">
    <div class="container tl-wrap">
      <header class="tl-header">
        <h2 class="tl-title">Timeline</h2>
        <p class="tl-subtitle">Share something with your future self.</p>
      </header>

      <section class="tl-panel card tl-card">
        <div class="card-body">
          <h3 class="tl-panelTitle">Post a message</h3>

          <% if (error) { %>
            <div class="alert alert-danger tl-alert" role="alert">
              <strong>Oops!</strong> <%= error %>
            </div>
          <% } %>
            <% if (user) { %>
          <form class="tl-form" action="/add-post" method="POST">
            <div class="tl-field">
              <textarea
                name="post"
                class="form-control tl-textarea"
                rows="4"
                placeholder="Type your post here (min 25 characters)..."
                required
              ></textarea>
              <div class="tl-hint">Minimum length: 25 characters.</div>
            </div>

            <div class="tl-actions">
              <button class="btn btn-primary tl-btnPrimary" type="submit">Post a message</button>
            </div>
          </form>
          <% } %>
        </div>
      </section>

      <section class="tl-feed">
        <% posts.forEach(post => { %>
          <article class="card tl-card tl-postCard mb-3">
            <div class="card-body">
              <div class="tl-meta">
  <span class="tl-date"><%= post.createdAt.toDateString() %></span>
  <% if (post.authorName) { %>
    <span class="tl-author"> - <%= post.authorName %></span>
  <% } %>
</div>

              <p class="tl-excerpt">
                <%= post.post.length > 150 ? post.post.substring(0,150) + "..." : post.post %>
              </p>

              <div class="tl-postActions">
                <a href="/posts/<%= post._id %>" class="btn btn-sm btn-outline-primary tl-btnOutline">
                  See More
                </a>
              </div>
            </div>

            <div class="comments-form">
              <% if (user) { %>
              <form method="POST" action="/post/add/new-comment/<%= post._id %>">
                <input type="text" placeholder="comment..." autocomplete="off" name="body">
                <button type="submit">Add Comment</button>
              </form>
              <% } %>
            </div>

            <div class="comment-container">
              <% if (post.comments && post.comments.length > 0) { %>
                <% post.comments.forEach(comment => { %>
                  <div class="comment-section">
                    <h4>
  <%= comment.body %>
  <% if (comment.authorName) { %>
    <small> - <%= comment.authorName %></small>
  <% } %>
</h4>
<% if (user) { %>
  <form action="/delete/comment/<%= comment._id %>/<%= post._id %>" method="GET">
    <button type="submit" class="comment-section-button">Delete</button>
  </form>
<% } %>
                  </div>
                <% }) %>
              <% } %>
            </div>

          </article>
        <% }) %>
      </section>
    </div>
  </main>
</body>
</html>